{
  "catalog_source": [
    {
      "dialect": "sqlserver",
      "essence": "column",
      "from_sql": "sys.objects AS o JOIN sys.schemas AS s ON s.schema_id = o.schema_id JOIN sys.columns AS c ON c.object_id = o.object_id JOIN sys.types AS ty ON ty.user_type_id = c.user_type_id",
      "where_sql": "o.type IN ('U', 'V')",
      "change_signal": "o.modify_date"
    },
    {
      "dialect": "sqlserver",
      "essence": "index",
      "from_sql": "sys.indexes AS i JOIN sys.objects AS o ON o.object_id = i.object_id JOIN sys.schemas AS s ON s.schema_id = o.schema_id JOIN sys.index_columns AS ic ON ic.object_id = i.object_id AND ic.index_id = i.index_id JOIN sys.columns AS c ON c.object_id = ic.object_id AND c.column_id = ic.column_id",
      "where_sql": "o.type = 'U' AND i.index_id > 0 AND i.is_primary_key = 0",
      "change_signal": "o.modify_date"
    },
    {
      "dialect": "sqlserver",
      "essence": "foreign_key",
      "from_sql": "sys.foreign_keys AS fk JOIN sys.objects AS o ON o.object_id = fk.parent_object_id JOIN sys.schemas AS s ON s.schema_id = o.schema_id JOIN sys.foreign_key_columns AS fkc ON fkc.constraint_object_id = fk.object_id JOIN sys.columns AS pc ON pc.object_id = fkc.parent_object_id AND pc.column_id = fkc.parent_column_id JOIN sys.objects AS ro ON ro.object_id = fk.referenced_object_id JOIN sys.columns AS rc ON rc.object_id = fkc.referenced_object_id AND rc.column_id = fkc.referenced_column_id",
      "where_sql": null,
      "change_signal": "o.modify_date"
    },
    {
      "dialect": "sqlserver",
      "essence": "primary_key",
      "from_sql": "sys.key_constraints AS kc JOIN sys.objects AS o ON o.object_id = kc.parent_object_id JOIN sys.schemas AS s ON s.schema_id = o.schema_id JOIN sys.index_columns AS ic ON ic.object_id = kc.parent_object_id AND ic.index_id = kc.unique_index_id JOIN sys.columns AS c ON c.object_id = ic.object_id AND c.column_id = ic.column_id",
      "where_sql": "kc.type = 'PK'",
      "change_signal": "o.modify_date"
    },
    {
      "dialect": "sqlite",
      "essence": "column",
      "from_sql": "sqlite_master AS m, pragma_table_info(m.name) AS ti",
      "where_sql": "m.type IN ('table', 'view')",
      "change_signal": null
    },
    {
      "dialect": "sqlite",
      "essence": "index",
      "from_sql": "sqlite_master AS m, pragma_index_list(m.name) AS il, pragma_index_info(il.name) AS ii",
      "where_sql": "m.type = 'table' AND il.origin = 'c'",
      "change_signal": null
    },
    {
      "dialect": "sqlite",
      "essence": "foreign_key",
      "from_sql": "sqlite_master AS m, pragma_foreign_key_list(m.name) AS fk",
      "where_sql": "m.type = 'table'",
      "change_signal": null
    },
    {
      "dialect": "sqlite",
      "essence": "primary_key",
      "from_sql": "sqlite_master AS m, pragma_table_info(m.name) AS ti",
      "where_sql": "m.type = 'table' AND ti.pk > 0",
      "change_signal": null
    },
    {
      "dialect": "duckdb",
      "essence": "column",
      "from_sql": "information_schema.columns AS c",
      "where_sql": null,
      "change_signal": null
    }
