{
  "catalog_source": [
    {
      "dialect": "postgresql", "essence": "check",
      "from_sql": "pg_constraint AS con JOIN pg_class AS c ON c.oid = con.conrelid JOIN pg_namespace AS n ON n.oid = c.relnamespace",
      "where_sql": "con.contype = 'c' AND n.nspname NOT IN ('pg_catalog','information_schema')",
      "change_signal": null
    },
    {
      "dialect": "postgresql", "essence": "unique",
      "from_sql": "pg_constraint AS con JOIN pg_class AS c ON c.oid = con.conrelid JOIN pg_namespace AS n ON n.oid = c.relnamespace CROSS JOIN LATERAL unnest(con.conkey) WITH ORDINALITY AS k(att, ord) JOIN pg_attribute AS a ON a.attrelid = con.conrelid AND a.attnum = k.att",
      "where_sql": "con.contype = 'u' AND n.nspname NOT IN ('pg_catalog','information_schema')",
      "change_signal": null
    },
    {
      "dialect": "postgresql", "essence": "type",
      "from_sql": "pg_type AS t JOIN pg_namespace AS n ON n.oid = t.typnamespace",
      "where_sql": "t.typtype IN ('e','d','r') AND n.nspname NOT IN ('pg_catalog','information_schema')",
      "change_signal": null
    }
  ],
  "catalog_attr": [
    {"dialect": "postgresql", "essence": "check", "ord": 0, "attr": "schema_name", "expr": "n.nspname"},
    {"dialect": "postgresql", "essence": "check", "ord": 1, "attr": "object_name", "expr": "c.relname"},
    {"dialect": "postgresql", "essence": "check", "ord": 2, "attr": "check_name", "expr": "con.conname"},
    {"dialect": "postgresql", "essence": "check", "ord": 3, "attr": "definition", "expr": "pg_get_constraintdef(con.oid)"},

    {"dialect": "postgresql", "essence": "unique", "ord": 0, "attr": "schema_name", "expr": "n.nspname"},
    {"dialect": "postgresql", "essence": "unique", "ord": 1, "attr": "object_name", "expr": "c.relname"},
    {"dialect": "postgresql", "essence": "unique", "ord": 2, "attr": "uq_name", "expr": "con.conname"},
    {"dialect": "postgresql", "essence": "unique", "ord": 3, "attr": "member_name", "expr": "a.attname"},
    {"dialect": "postgresql", "essence": "unique", "ord": 4, "attr": "key_ordinal", "expr": "k.ord"},

    {"dialect": "postgresql", "essence": "type", "ord": 0, "attr": "schema_name", "expr": "n.nspname"},
    {"dialect": "postgresql", "essence": "type", "ord": 1, "attr": "type_name", "expr": "t.typname"},
    {"dialect": "postgresql", "essence": "type", "ord": 2, "attr": "kind", "expr": "CASE t.typtype WHEN 'e' THEN 'enum' WHEN 'd' THEN 'domain' WHEN 'r' THEN 'range' END"},
    {"dialect": "postgresql", "essence": "type", "ord": 3, "attr": "base_type", "expr": "format_type(t.typbasetype, t.typtypmod)"}
  ]
}
