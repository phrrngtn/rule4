{
  "catalog_source": [
    {
      "dialect": "sqlserver", "essence": "database",
      "from_sql": "sys.databases AS d", "where_sql": null, "change_signal": null
    },
    {
      "dialect": "sqlserver", "essence": "login",
      "from_sql": "sys.server_principals AS sp",
      "where_sql": "sp.type IN ('S','U','G')", "change_signal": null
    },
    {
      "dialect": "sqlserver", "essence": "schema",
      "from_sql": "sys.schemas AS s JOIN sys.database_principals AS p ON p.principal_id = s.principal_id",
      "where_sql": null, "change_signal": null
    },
    {
      "dialect": "sqlserver", "essence": "database_principal",
      "from_sql": "sys.database_principals AS p",
      "where_sql": "p.type IN ('S','U','G','R')", "change_signal": null
    }
  ],
  "catalog_attr": [
