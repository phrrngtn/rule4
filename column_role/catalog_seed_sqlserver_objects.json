    {"dialect": "sqlserver", "essence": "login", "ord": 2, "attr": "is_disabled", "expr": "sp.is_disabled"},
    {"dialect": "sqlserver", "essence": "login", "ord": 3, "attr": "default_database", "expr": "sp.default_database_name"},

    {"dialect": "sqlserver", "essence": "schema", "ord": 0, "attr": "schema_name", "expr": "s.name"},
    {"dialect": "sqlserver", "essence": "schema", "ord": 1, "attr": "owner", "expr": "p.name"},

    {"dialect": "sqlserver", "essence": "database_principal", "ord": 0, "attr": "principal_name", "expr": "p.name"},
    {"dialect": "sqlserver", "essence": "database_principal", "ord": 1, "attr": "type_desc", "expr": "p.type_desc"},
